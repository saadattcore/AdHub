import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.adhub.entity.ProductEntity;
import com.adhub.entity.UserEntity;
import com.adhub.service.UserManagementService;

@RestController
@RequestMapping("/api/usermanagement/")
public class UserManagementController {

	private UserManagementService userService;	

	public UserManagementController(UserManagementService userService) {
		this.userService = userService;				
	}

	@GetMapping("users")
	public String get() {	
		
				
		UserEntity user = new UserEntity();
		user.setName("Shah Saab");		
		this.userService.updateUser(752L, user);
		
		System.out.println(this.userService.getUser(752L).getName());
		
	
		
		return "Spring MVC 6";
	}

	@GetMapping("users/{id}")
	public ResponseEntity<UserEntity> get(@PathVariable("id") Long id) {

		System.out.println(id);
		
		UserEntity user = this.userService.getUser(id);
		
		System.out.println(user.getName());
		
		user.getProducts().forEach(p -> System.out.println(p.getProductName()));
		
		return ResponseEntity
		.status(HttpStatus.OK)
		.body(user);
		
	}

	@PostMapping("users")
	
	
	
	public void save() {

	}

	@PutMapping("users")
