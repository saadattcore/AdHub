package com.adhub.controller;

import java.util.ArrayList;
import java.util.List;

import org.springframework.http.HttpStatus;
import org.springframework.http.HttpStatusCode;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.adhub.dto.ProductDto;
import com.adhub.dto.UserDto;
import com.adhub.entity.ProductEntity;
import com.adhub.entity.UserEntity;
import com.adhub.service.UserManagementService;

@RestController
@RequestMapping("/api/usermanagement/")
public class UserManagementController {

	private UserManagementService userService;	

	public UserManagementController(UserManagementService userService) {
		this.userService = userService;				
	}

	@GetMapping("users")
	public String get() {							
		UserEntity user = new UserEntity();
		user.setName("Shah Saab");		
		this.userService.updateUser(752L, user);
		System.out.println(this.userService.getUser(752L).getName());		
		return "Spring MVC 6";
	}

	@GetMapping("users/{id}")
	public ResponseEntity<UserDto> get(@PathVariable("id") Long id) {

		System.out.println(id);
		
		UserEntity user = this.userService.getUser(id);
		
		System.out.println(user.getName());
		
		user.getProducts().forEach(p -> System.out.println(p.getProductName()));
		
		UserDto response = new UserDto();
		response.setId(user.getId());
		response.setName(user.getName());
		
		List<ProductDto> productsDto = new ArrayList<ProductDto>();
		
		for (ProductEntity product : user.getProducts()) {
			
			ProductDto productDto = new ProductDto();
			productDto.setId(product.getId());
			productDto.setMake(product.getMake());
			productDto.setModel(product.getModel());
			productDto.setCategory(product.getCategory());
			productDto.setYear(product.getYear());
			productDto.setProductName(product.getProductName());
			productsDto.add(productDto);
			
			
			
		}
		
		response.setProducts(productsDto);
		
		return ResponseEntity
		.status(HttpStatus.OK)
		.body(response);
		
	}

	@PostMapping("users")	
	public ResponseEntity<Long> save(@RequestBody UserDto userDto) {
		System.out.println(userDto);
		
		UserEntity dbUser = new UserEntity();
		dbUser.setName(userDto.getName());
		
		List<ProductEntity> dbProducts = userDto
											.getProducts()
											.stream()
											.map(p -> toProductEntity(p,dbUser)).toList();
		
		dbUser.setProducts(dbProducts);
		
		 this.userService.saveUser(dbUser);		
		
		 return ResponseEntity
		 .status(HttpStatus.OK)
		 .body(dbUser.getId());
		
		
	}

	@PutMapping("users")
	public void update(@PathVariable Long userId, @RequestBody UserEntity userDto) {

		this.userService.updateUser(userId, userDto);
		
	}
	
	private void saveToDb() {
	
		UserEntity seller = new UserEntity();
		seller.setName("Ali");
		
		ProductEntity iphone = new ProductEntity();
		iphone.setProductName("Iphone");
		iphone.setMake("Apple");
		iphone.setModel("11 Pro");
		iphone.setYear(2025);
		iphone.setCategory("CellPhone");
		iphone.setSeller(seller);
		
		
		ProductEntity civic = new ProductEntity();
		civic.setProductName("City");
		civic.setMake("Honda");
		civic.setModel("City Aspire");
		civic.setYear(2013);
		civic.setCategory("Car");
		civic.setSeller(seller);
		
		List<ProductEntity> products = new ArrayList<ProductEntity>();
		products.add(iphone);
		products.add(civic);
		
		
		
		seller.setProducts(products);
		
		userService.saveUser(seller);
		
	}
	
	private ProductEntity toProductEntity(ProductDto dto, UserEntity dbUser) {
		ProductEntity p =  	new	ProductEntity();
		p.setCategory(dto.getCategory());
		p.setMake(dto.getMake());
		p.setModel(dto.getModel());
		p.setProductName(dto.getProductName());
		p.setYear(dto.getYear());
		p.setSeller(dbUser);
		
		return p;		
	}

}
