	private void saveToDb() {
	
		UserEntity seller = new UserEntity();
		seller.setName("Ali");
		
		ProductEntity iphone = new ProductEntity();
		iphone.setProductName("Iphone");
		iphone.setMake("Apple");
		iphone.setModel("11 Pro");
		iphone.setYear(2025);
		iphone.setCategory("CellPhone");
		iphone.setSeller(seller);
		
		
		ProductEntity civic = new ProductEntity();
		civic.setProductName("City");
		civic.setMake("Honda");
		civic.setModel("City Aspire");
		civic.setYear(2013);
		civic.setCategory("Car");
		civic.setSeller(seller);
		
		List<ProductEntity> products = new ArrayList<ProductEntity>();
		products.add(iphone);
		products.add(civic);
		
		
		
		seller.setProducts(products);
		
		userService.saveUser(seller);
		
	}
	

}
